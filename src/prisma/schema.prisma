// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
  CAR
}

enum ListingType {
  SALE
  RENT
}

enum PropertyStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum BookingStatus {
  PENDING
  APPROVED
  DECLINED
}

enum MessageType {
  PAYMENT
  MESSAGE
}

enum OtpType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model User {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  userName        String   @default("")
  email           String   @unique
  password        String
  isAdmin         Boolean  @default(false)
  profilePicture  String   @default("https://res.cloudinary.com/djoahpirg/image/upload/v1745277187/wepadt9fizw8vlmnqiyz.jpg")
  role            Role     @default(USER)
  isOnline        Boolean  @default(false)
  isEmailVerified Boolean  @default(false)

  provider      String?   // "google" | "apple"
  providerId    String?   // OAuth user ID
  
  // Relation to tokens
  refreshTokens   RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Self-relation for friends
  friends  User[] @relation("Friends")
  friendOf User[] @relation("Friends")

  // Relations
  agent            Agent?
  properties       Property[]     @relation("AgentProperties")
  agentBookings    Booking[]      @relation("AgentBookings")
  customerBookings Booking[]      @relation("CustomerBookings")
  conversations    Conversation[] @relation("ConversationParticipants")
  messages         Message[]      @relation("UserMessages")
  reviews          Review[]
  otps             OTP[]

  @@index([email])
  @@index([role])
}

model OTP {
  id        String   @id @default(uuid())
  code      String // hashed
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  otpType   OtpType
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique // Store a hash of the token for better security
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Property {
  id          String         @id @default(uuid())
  title       String
  description String
  price       Float
  type        PropertyType
  status      PropertyStatus
  images      String[]
  tags        String[]
  amenities   String[]
  bedrooms    Int
  bathrooms   Int
  featured    Boolean        @default(false)

  agentId String
  agent   User   @relation("AgentProperties", fields: [agentId], references: [id], onDelete: Cascade)

  location      Location?
  bookings      Booking[]
  conversations Conversation[]
  reviews       Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([price])
  @@index([type])
  @@index([status])
  @@index([agentId])
  @@index([featured])
}

model Location {
  id      String @id @default(uuid())
  address String
  city    String
  state   String
  country String

  latitude  Float
  longitude Float

  propertyId String   @unique
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@index([propertyId])
  @@index([city])
  @@index([country])
}

model Agent {
  id            String @id @default(uuid())
  fullName      String
  email         String @unique
  phone         String
  bankCode      String
  accountNumber String
  accountName   String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([email])
}

model Booking {
  id String @id @default(uuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  agentId String
  agent   User   @relation("AgentBookings", fields: [agentId], references: [id], onDelete: Cascade)

  customerId String
  customer   User   @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)

  date   DateTime
  status BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([agentId])
  @@index([customerId])
  @@index([status])
}

model Conversation {
  id String @id @default(uuid())

  participants User[] @relation("ConversationParticipants")

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  lastMessage String @default("")

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
}

model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)

  content String?
  type    MessageType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([type])
}

model Review {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  rating  Int     @default(0)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@index([rating])
}
